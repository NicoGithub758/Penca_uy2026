@model Penca_uy2026.Models.ViewModels.ConfirmarPasswordViewModel

@{
    ViewData["Title"] = "Configurar Contraseña";
    Layout = "_Layout"; // O el layout limpio que uses para el login
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-header bg-primary text-white text-center py-3 rounded-top-4">
                    <h4 class="m-0 fw-bold"><i class="bi bi-shield-lock-fill me-2"></i>Activar Cuenta de Admin</h4>
                    <small class="text-white-50">Estás a un paso de activar el panel de tu sitio</small>
                </div>
                <div class="card-body p-4">

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small"></div>
                    }

                    <form asp-controller="Account" asp-action="ConfigurarPassword" method="post" asp-antiforgery="false">

                        <input type="hidden" name="Token" value="@Model.Token" />

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold">Nueva Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                                <input asp-for="Password" type="password" class="form-control" placeholder="Mínimo 6 caracteres" required />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirmar Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-lock-check"></i></span>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repite la contraseña" required />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-semibold shadow-sm">
                                <i class="bi bi-check-circle-fill me-2"></i>Guardar y Activar Cuenta
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>