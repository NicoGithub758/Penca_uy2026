@{
    ViewData["Title"] = "Panel de administracion";
}

<div class="d-flex flex-column gap-4">
    <section class="py-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center">
            <div>
                <h1 class="h2 fw-bold mb-2">Panel de administracion</h1>
                <p class="text-muted mb-0">Gestiona pencas, competiciones, sitios y resultados desde un solo lugar.</p>
            </div>
            <a class="btn btn-primary" asp-controller="Penca" asp-action="Create">
                <i class="bi bi-plus-circle"></i> Nueva penca
            </a>
        </div>
    </section>

    <section class="row g-3">
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <span class="bg-primary-subtle text-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                            <i class="bi bi-trophy-fill"></i>
                        </span>
                        <h2 class="h5 mb-0">Pencas</h2>
                    </div>
                    <p class="text-muted flex-grow-1">Consulta, administra y crea pencas para las competiciones disponibles.</p>
                    <a class="btn btn-outline-primary w-100" asp-controller="Penca" asp-action="Index">
                        Ver pencas
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <span class="bg-success-subtle text-success rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                            <i class="bi bi-globe-americas"></i>
                        </span>
                        <h2 class="h5 mb-0">Sitios</h2>
                    </div>
                    <p class="text-muted flex-grow-1">Crea nuevos sitios y administra sus datos iniciales de acceso.</p>
                    <a class="btn btn-outline-success w-100" asp-controller="AdminAuth" asp-action="CrearSitio">
                        Crear sitio
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <span class="bg-warning-subtle text-warning rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                            <i class="bi bi-calendar-check"></i>
                        </span>
                        <h2 class="h5 mb-0">Resultados</h2>
                    </div>
                    <p class="text-muted flex-grow-1">Revisa las pencas activas y los partidos pendientes de actualizacion.</p>
                    <a class="btn btn-outline-warning w-100" asp-controller="Penca" asp-action="Index">
                        Administrar partidos
                    </a>
                </div>
            </div>
        </div>
    </section>
</div>
