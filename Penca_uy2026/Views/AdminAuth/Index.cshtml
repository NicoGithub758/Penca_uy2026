@{
    ViewData["Title"] = "Panel de administracion";
}

<div class="d-flex flex-column gap-4">
    <section class="py-4">
        <div>
            <h1 class="h2 fw-bold mb-2">Panel de administracion</h1>
            <p class="text-muted mb-0">Gestiona pencas, sitios y parametros generales desde un solo lugar.</p>
        </div>
    </section>

    <section class="d-flex flex-column gap-3">
        <a class="card shadow-sm text-decoration-none text-reset" asp-controller="Penca" asp-action="Index">
            <div class="card-body d-flex align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <span class="bg-primary-subtle text-primary rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 44px; height: 44px;">
                        <i class="bi bi-trophy-fill"></i>
                    </span>
                    <div>
                        <h2 class="h5 mb-1">Pencas</h2>
                        <p class="text-muted mb-0">Consulta, administra y crea pencas para las competiciones disponibles.</p>
                    </div>
                </div>
                <i class="bi bi-chevron-right text-muted"></i>
            </div>
        </a>

        <a class="card shadow-sm text-decoration-none text-reset" asp-controller="AdminAuth" asp-action="CrearSitio">
            <div class="card-body d-flex align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <span class="bg-success-subtle text-success rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 44px; height: 44px;">
                        <i class="bi bi-plus-circle"></i>
                    </span>
                    <div>
                        <h2 class="h5 mb-1">Crear sitio</h2>
                        <p class="text-muted mb-0">Registra un nuevo sitio y crea su administrador inicial.</p>
                    </div>
                </div>
                <i class="bi bi-chevron-right text-muted"></i>
            </div>
        </a>

        <a class="card shadow-sm text-decoration-none text-reset" asp-controller="AdminAuth" asp-action="VerSitios">
            <div class="card-body d-flex align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <span class="bg-info-subtle text-info rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 44px; height: 44px;">
                        <i class="bi bi-globe-americas"></i>
                    </span>
                    <div>
                        <h2 class="h5 mb-1">Sitios disponibles</h2>
                        <p class="text-muted mb-0">Lista los sitios registrados, sus URL, estado y tipo de registro.</p>
                    </div>
                </div>
                <i class="bi bi-chevron-right text-muted"></i>
            </div>
        </a>

        <a class="card shadow-sm text-decoration-none text-reset" asp-controller="AdminAuth" asp-action="Estadisticas">
            <div class="card-body d-flex align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <span class="bg-warning-subtle text-warning rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 44px; height: 44px;">
                        <i class="bi bi-bar-chart-fill"></i>
                    </span>
                    <div>
                        <h2 class="h5 mb-1">Estadisticas</h2>
                        <p class="text-muted mb-0">Revisa metricas generales de pencas, usuarios, sitios y recaudacion.</p>
                    </div>
                </div>
                <i class="bi bi-chevron-right text-muted"></i>
            </div>
        </a>

        <a class="card shadow-sm text-decoration-none text-reset" asp-controller="ParametrosSistema" asp-action="Index">
            <div class="card-body d-flex align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <span class="bg-secondary-subtle text-secondary rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 44px; height: 44px;">
                        <i class="bi bi-sliders"></i>
                    </span>
                    <div>
                        <h2 class="h5 mb-1">Parametros del sistema</h2>
                        <p class="text-muted mb-0">Configura parametros globales de la plataforma.</p>
                    </div>
                </div>
                <i class="bi bi-chevron-right text-muted"></i>
            </div>
        </a>
    </section>
</div>
