@{
    ViewData["Title"] = "Panel de administracion";
}

<div class="d-flex flex-column gap-4">
    <section class="py-4">
        <div>
            <h1 class="h2 fw-bold mb-2">Panel de administracion</h1>
            <p class="text-muted mb-0">Gestiona pencas, sitios y parametros generales desde un solo lugar.</p>
        </div>
    </section>

    <section class="row g-3">
        <div class="col-12 col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <span class="bg-primary-subtle text-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                            <i class="bi bi-trophy-fill"></i>
                        </span>
                        <h2 class="h5 mb-0">Pencas</h2>
                    </div>
                    <p class="text-muted flex-grow-1">Consulta, administra y crea pencas para las competiciones disponibles.</p>
                    <a class="btn btn-outline-primary w-100" asp-controller="Penca" asp-action="Index">
                        Ir a pencas
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <span class="bg-success-subtle text-success rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                            <i class="bi bi-plus-circle"></i>
                        </span>
                        <h2 class="h5 mb-0">Crear sitio</h2>
                    </div>
                    <p class="text-muted flex-grow-1">Registra un nuevo sitio y crea su administrador inicial.</p>
                    <a class="btn btn-outline-success w-100" asp-controller="AdminAuth" asp-action="CrearSitio">
                        Crear sitio
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <span class="bg-info-subtle text-info rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                            <i class="bi bi-globe-americas"></i>
                        </span>
                        <h2 class="h5 mb-0">Sitios disponibles</h2>
                    </div>
                    <p class="text-muted flex-grow-1">Lista los sitios registrados, sus URL, estado y tipo de registro.</p>
                    <a class="btn btn-outline-info w-100" asp-controller="Sitios" asp-action="Index">
                        Listar sitios
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <span class="bg-secondary-subtle text-secondary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                            <i class="bi bi-sliders"></i>
                        </span>
                        <h2 class="h5 mb-0">Parametros del sistema</h2>
                    </div>
                    <p class="text-muted flex-grow-1">Configura parametros globales de la plataforma.</p>
                    <a class="btn btn-outline-secondary w-100" asp-controller="ParametrosSistema" asp-action="Index">
                        Gestionar parametros
                    </a>
                </div>
            </div>
        </div>
    </section>
</div>
