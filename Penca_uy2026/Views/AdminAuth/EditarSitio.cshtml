@model Penca_uy2026.Models.Sitio

@{
    ViewData["Title"] = "Modificar Sitio";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-dark text-white py-3 rounded-top-4">
                    <h4 class="m-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Modificar Configuración del Sitio</h4>
                </div>
                <div class="card-body p-4">
                    
                    <form asp-controller="AdminAuth" asp-action="EditarSitio" asp-route-id="@Model.Id" method="post" asp-antiforgery="false" enctype="multipart/form-data">
                        
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label fw-semibold">Nombre del Sitio</label>
                            <input asp-for="Nombre" class="form-control form-control-lg rounded-3" placeholder="Ej. Mi Penca Deportiva" required />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Url" class="form-label fw-semibold">URL del Sitio</label>
                            <input asp-for="Url" class="form-control rounded-3 bg-light" readonly />
                            <div class="form-text">La URL se actualizará automáticamente si cambias el slug.</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold d-block">Estado del Tenant</label>
                            <div class="form-check form-switch form-check-inline bg-light p-2 rounded-3 border px-4">
                                <input class="form-check-input ms-0 me-2" type="checkbox" asp-for="Activo" id="switchActivo">
                                <label class="form-check-label fw-medium" for="switchActivo">Sitio Activo / Operacional</label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Slug" class="form-label fw-semibold">Slug del Sitio</label>
                            <input asp-for="Slug" class="form-control rounded-3" placeholder="mi-penca" required />
                            <span asp-validation-for="Slug" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tipo de Registro</label>
                            <select asp-for="TipoRegistro" class="form-select rounded-3">
                                <option value="0">Abierta (Cualquiera se une)</option>
                                <option value="1">Abierta con Autorización (Requiere aprobar)</option>
                                <option value="2">Solo con Invitación (Link privado)</option>
                                <option value="3">Cerrada (Nadie más puede unirse)</option>
                            </select>
                            <span asp-validation-for="TipoRegistro" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Color Principal</label>
                            <input type="color" asp-for="ColorPrincipal" class="form-control form-control-color" />
                            <span asp-validation-for="ColorPrincipal" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Logo del Sitio (Opcional)</label>
                            <input type="file" name="logoFile" class="form-control rounded-3" accept="image/*" />
                            <div class="form-text">Si no subes nada, se mantendrá el logo actual.</div>
                        </div>

                        <input type="hidden" asp-for="Descripcion" />
                        <input type="hidden" asp-for="LogoUrl" />

                        <div class="d-flex justify-content-end gap-2 border-top pt-3">
                            <a asp-action="VerSitios" class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-semibold">Guardar Cambios</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>