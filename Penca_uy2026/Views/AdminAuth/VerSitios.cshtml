@model IEnumerable<Penca_uy2026.Models.Sitio>

@{
    ViewData["Title"] = "Sitios Disponibles";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container my-5 animate__animated animate__fadeIn">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center border-bottom pb-3 mb-4">
        <div>
            <h1 class="fw-bold text-dark m-0 d-flex align-items-center gap-2">
                <i class="bi bi-globe text-primary"></i> Sitios Disponibles
            </h1>
            <p class="text-muted m-0 mt-1">Gestión y control de los tenants activos en la plataforma</p>
        </div>
        <a asp-action="CrearSitio" class="btn btn-primary btn-lg shadow-sm mt-3 mt-md-0 d-flex align-items-center gap-2 rounded-pill px-4 fw-semibold">
            <i class="bi bi-plus-circle-fill"></i> Crear Nuevo Sitio
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-check-circle-fill fs-5"></i>
            <div>@TempData["Success"]</div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-light rounded-4 border border-dashed mt-4">
            <i class="bi bi-folder-x text-muted display-1"></i>
            <h3 class="mt-3 fw-semibold">No hay sitios registrados</h3>
            <p class="text-muted">Comienza creando tu primer tenant haciendo click en el botón superior.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-dark text-white" style="--bs-bg-opacity: .95;">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase fs-7 tracking-wider" style="width: 80px;">ID</th>
                            <th class="py-3 text-uppercase fs-7 tracking-wider">Nombre del Sitio</th>
                            <th class="py-3 text-uppercase fs-7 tracking-wider">URL (Vercel / Railway)</th>
                            <th class="py-3 text-uppercase fs-7 tracking-wider">Slug</th>
                            <th class="py-3 text-uppercase fs-7 tracking-wider text-center" style="width: 130px;">Estado</th>
                            <th class="pe-4 py-3 text-uppercase fs-7 tracking-wider text-end" style="width: 220px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sitio in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-secondary">#@sitio.Id</td>
                                <td>
                                    <span class="fw-bold text-dark fs-6">@sitio.Nombre</span>
                                </td>
                                <td>
                                    <a href="@sitio.Url" target="_blank" class="text-decoration-none text-primary fw-medium d-inline-flex align-items-center gap-1 hover-link">
                                        @sitio.Url <i class="bi bi-box-arrow-up-right fs-7"></i>
                                    </a>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border px-2 py-1.5 font-monospace">@sitio.Slug</span>
                                </td>
                                <td class="text-center">
                                    @if (sitio.Activo)
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-semibold border border-success-subtle">
                                            <i class="bi bi-check-circle-fill me-1"></i> Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill fw-semibold border border-danger-subtle">
                                            <i class="bi bi-x-circle-fill me-1"></i> Inactivo
                                        </span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="d-inline-flex gap-2 align-items-center">
                                        <a asp-action="EditarSitio" asp-route-id="@sitio.Id" class="btn btn-outline-secondary btn-sm rounded-3 px-2.5 py-1.5 d-flex align-items-center gap-1" title="Modificar Sitio">
                                            <i class="bi bi-pencil-square"></i> <span class="d-none d-sm-inline">Modificar</span>
                                        </a>
                                        
                                        <form asp-action="EliminarSitio" asp-route-id="@sitio.Id" method="post" class="m-0" onsubmit="return confirm('¿Estás seguro de que deseas eliminar el sitio &quot;@sitio.Nombre&quot;? Esta acción borrará el tenant y no se puede deshacer.');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-3 px-2.5 py-1.5 d-flex align-items-center gap-1" title="Eliminar Sitio">
                                                <i class="bi bi-trash3-fill"></i> <span class="d-none d-sm-inline">Eliminar</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    /* Ajustes estéticos personalizados */
    .fs-7 { font-size: 0.75rem; }
    .tracking-wider { letter-spacing: 0.05em; }
    .hover-link:hover { text-decoration: underline !important; }
    .table tbody tr { transition: background-color 0.2s ease; }
    .card { border-radius: 12px; }
    .font-monospace { font-family: SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; }
</style>