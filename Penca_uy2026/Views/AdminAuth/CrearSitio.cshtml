@model Penca_uy2026.Models.ViewModels.CrearSitioViewModel

<div class="max-w-md mx-auto mt-10 bg-white p-8 rounded-lg shadow-md">
    <h2 class="text-2xl font-bold mb-6 text-center">Registrar Nuevo Sitio</h2>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="bg-red-100 text-red-700 p-3 rounded mb-4">
            <div asp-validation-summary="All"></div>
        </div>
    }

    <form asp-controller="AdminAuth" asp-action="CrearSitio" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-4">
            <label class="block font-bold">Nombre del Sitio</label>
            <input asp-for="NombreSitio" class="w-full border p-2 rounded" placeholder="Mi Penca Pro" />
        </div>

        <div class="mb-4">
            <label class="block font-bold">URL de Vercel (sin http)</label>
            <input asp-for="UrlVercel" class="w-full border p-2 rounded" placeholder="mipenca.vercel.app" />
        </div>

        <hr class="my-6" />
        <h3 class="text-lg font-semibold mb-4">Datos del Administrador</h3>

        <div class="mb-4">
            <label class="block font-bold">Nombre del Administrador</label>
            <input asp-for="NombreAdmin" class="w-full border p-2 rounded" placeholder="Juan Pérez" />
        </div>

        <div class="mb-4">
            <label class="block font-bold">Email del Administrador</label>
            <input asp-for="EmailAdmin" type="email" class="w-full border p-2 rounded" placeholder="admin@ejemplo.com" />
        </div>

        <div class="mb-6">
            <label class="block font-bold">Password del Administrador</label>
            <input asp-for="PasswordAdmin" type="password" class="w-full border p-2 rounded" />
        </div>

        <button type="submit" class="w-full bg-green-600 text-white font-bold py-2 rounded hover:bg-green-700 transition duration-300">
            Guardar Sitio y Admin
        </button>
    </form>
</div>