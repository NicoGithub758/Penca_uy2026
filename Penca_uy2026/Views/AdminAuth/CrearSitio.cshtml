@model Penca_uy2026.Models.ViewModels.CrearSitioViewModel

@{
    ViewData["Title"] = "Nuevo Sitio";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0" style="border-radius: 15px;">
                <div class="card-header bg-dark text-white text-center py-3" style="border-radius: 15px 15px 0 0;">
                    <h2 class="h4 mb-0"><i class="bi bi-plus-circle me-2"></i>Registrar Nuevo Sitio</h2>
                </div>
                
                <div class="card-body p-4">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger shadow-sm">
                            <div asp-validation-summary="All" class="small"></div>
                        </div>
                    }

                    <form asp-controller="AdminAuth" asp-action="CrearSitio" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <h5 class="text-primary border-bottom pb-2 mb-3">Configuración del Sitio</h5>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre del Sitio</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-tag"></i></span>
                                <input asp-for="NombreSitio" id="NombreSitio" class="form-control" placeholder="Ej: Mi Penca Pro" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Slug (Identificador URL)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-link-45deg"></i></span>
                                <input asp-for="Slug" id="Slug" class="form-control" placeholder="ej-mi-penca" required />
                            </div>
                            <div class="form-text text-muted">Será la URL única de tu penca: tupenca.uy/<strong>ej-mi-penca</strong></div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Logo del Sitio (Opcional)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-image"></i></span>
                                <input asp-for="Logo" type="file" class="form-control" accept="image/png, image/jpeg, image/webp" />
                            </div>
                            <div class="form-text text-muted">Formatos soportados: JPG, PNG, WEBP.</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Modalidad de Registro</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-shield-check"></i></span>
                                <select asp-for="TipoRegistro" class="form-select">
                                    <option value="0">Abierta (Cualquiera se une)</option>
                                    <option value="1">Abierta con Autorización (Requiere aprobar)</option>
                                    <option value="2">Solo con Invitación (Link privado)</option>
                                    <option value="3">Cerrada (Nadie más puede unirse)</option>
                                </select>
                            </div>
                        </div>

                        <h5 class="text-primary border-bottom pb-2 mb-3 mt-4">Cuenta de Administrador</h5>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre Completo</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input asp-for="NombreAdmin" class="form-control" placeholder="Juan Pérez" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Email</label>
                                <input asp-for="EmailAdmin" type="email" class="form-control" placeholder="admin@ejemplo.com" required />
                            </div>                
                        </div>

                        <div class="d-grid gap-2 mt-2">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">
                                <i class="bi bi-cloud-check me-2"></i>Guardar Sitio y Administrador
                            </button>
                            <a asp-action="Index" asp-controller="Penca" class="btn btn-link text-muted mt-2">Cancelar y Volver</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const nombreInput = document.getElementById('NombreSitio');
            const slugInput = document.getElementById('Slug');

            nombreInput.addEventListener('input', function () {
                // Solo auto-completar si el usuario no ha editado manualmente el slug
                // (Para una versión más robusta se podría usar una flag "isEdited")
                const text = nombreInput.value;
                const slug = text
                    .toLowerCase()
                    .normalize("NFD").replace(/[\u0300-\u036f]/g, "") // Quitar tildes
                    .replace(/[^a-z0-9 ]/g, "") // Quitar caracteres especiales
                    .trim()
                    .replace(/\s+/g, "-"); // Reemplazar espacios por guiones
                
                slugInput.value = slug;
            });
        });
    </script>
}