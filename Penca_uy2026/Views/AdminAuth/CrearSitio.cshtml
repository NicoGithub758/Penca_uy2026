@model Penca_uy2026.Models.CrearSitioViewModel

@{
    ViewData["Title"] = "Registrar Nuevo Cliente";
}

<div class="min-h-screen bg-gray-100 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md mx-auto bg-white rounded-lg shadow-md overflow-hidden">
        <div class="px-6 py-8">
            <h2 class="text-2xl font-bold text-center text-gray-800 mb-8">Registrar Nuevo Sitio</h2>

            @if (ViewBag.Error != null)
            {
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="CrearSitio" method="post" class="space-y-6">
                <div class="border-b pb-4">
                    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Datos de la Plataforma</h3>
                    <div>
                        <label class="block text-sm font-medium text-gray-700">Nombre de la Empresa/Sitio</label>
                        <input asp-for="NombreSitio" type="text" required class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="Ej: Penca Empresa X">
                    </div>
                    <div class="mt-4">
                        <label class="block text-sm font-medium text-gray-700">URL de Vercel (Host)</label>
                        <input asp-for="UrlVercel" type="text" required class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="empresa-x.vercel.app">
                    </div>
                </div>

                <div>
                    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Datos del Administrador del Sitio</h3>
                    <div>
                        <label class="block text-sm font-medium text-gray-700">Nombre Completo</label>
                        <input asp-for="NombreAdmin" type="text" required class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                    </div>
                    <div class="mt-4">
                        <label class="block text-sm font-medium text-gray-700">Email del Administrador</label>
                        <input asp-for="EmailAdmin" type="email" required class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                    </div>
                    <div class="mt-4">
                        <label class="block text-sm font-medium text-gray-700">Contraseña Temporal</label>
                        <input asp-for="PasswordAdmin" type="password" required class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                    </div>
                </div>

                <div>
                    <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                        Crear Sitio y Administrador
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>