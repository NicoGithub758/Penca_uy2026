@model Penca_uy2026.Models.ViewModels.EstadisticasViewModel

@{
    ViewData["Title"] = "Panel de Estadísticas";
}

<style>
    :root {
        --brand:       #e05c2a;
        --brand-light: #fff5f0;
        --border:      #e5e7eb;
        --text-main:   #111827;
        --text-muted:  #6b7280;
        --bg-page:     #f9fafb;
        --radius:      12px;
    }

    body { background: var(--bg-page); }

    .s-header {
        background: #e05c2a;
        color: #fff;
        padding: 2rem 1.75rem 1.75rem;
        border-radius: var(--radius);
        margin-bottom: 1.5rem;
    }
    .s-header h2 { margin: 0 0 .2rem; font-size: 1.4rem; font-weight: 700; }
    .s-header p  { margin: 0; opacity: .75; font-size: .875rem; }

    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 10px;
        margin-bottom: 1.5rem;
    }
    .kpi {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1rem 1.1rem;
    }
    .kpi-lbl { font-size: .72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: .05em; margin-bottom: .3rem; }
    .kpi-val { font-size: 1.5rem; font-weight: 700; color: var(--text-main); line-height: 1; }
    .kpi-sub { font-size: .75rem; color: var(--text-muted); margin-top: .3rem; }

    .card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        margin-bottom: 1.25rem;
        overflow: hidden;
    }
    .card-hdr {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: .65rem;
    }
    .card-hdr .icon {
        width: 34px; height: 34px;
        border-radius: 8px;
        background: var(--brand-light);
        color: var(--brand);
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem; flex-shrink: 0;
    }
    .card-hdr h5 { margin: 0; font-size: .9rem; font-weight: 700; color: var(--text-main); }
    .card-hdr p  { margin: 0; font-size: .78rem; color: var(--text-muted); }
    .card-body   { padding: 1.25rem; }

    .chart-wrap { position: relative; width: 100%; height: 260px; }
    .chart-wrap-lg { position: relative; width: 100%; height: 360px; }

    .filters {
        padding: .6rem 1.25rem;
        border-bottom: 1px solid var(--border);
        display: flex; gap: .4rem; flex-wrap: wrap;
        background: var(--brand-light);
    }
    .fbtn {
        padding: .25rem .75rem;
        border-radius: 20px;
        border: 1px solid var(--brand);
        background: transparent;
        color: var(--brand);
        font-size: .74rem; font-weight: 600;
        cursor: pointer;
        transition: background .15s, color .15s;
    }
    .fbtn.active, .fbtn:hover { background: var(--brand); color: #fff; }

    .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
        margin-bottom: 1.25rem;
    }
    @@media (max-width: 680px) { .two-col { grid-template-columns: 1fr; } }

    .site-table { width: 100%; border-collapse: collapse; font-size: .82rem; }
    .site-table th {
        text-align: left; font-weight: 600; font-size: .72rem;
        color: var(--text-muted); padding: .55rem .85rem;
        border-bottom: 1px solid var(--border);
        text-transform: uppercase; letter-spacing: .04em;
        background: #fafafa;
    }
    .site-table td { padding: .6rem .85rem; border-bottom: 1px solid var(--border); color: var(--text-main); }
    .site-table tr:last-child td { border-bottom: none; }
    .site-table tr:hover td { background: var(--brand-light); }
</style>

<div class="container-fluid px-4 py-4">

    <!-- Header -->
    <div class="s-header">
        <h2>📊 Panel de Estadísticas</h2>
        <p>Resumen general de actividad · Penca UY 2026</p>
    </div>

    <!-- KPIs -->
    <div class="kpi-grid">
        <div class="kpi">
            <div class="kpi-lbl">🏆 Total pencas</div>
            <div class="kpi-val">@Model.TotalPencas</div>
        </div>
        <div class="kpi">
            <div class="kpi-lbl">👥 Jugadores</div>
            <div class="kpi-val">@Model.TotalUsuarios</div>
            <div class="kpi-sub">+ @Model.TotalAdmins admins</div>
        </div>
        <div class="kpi">
            <div class="kpi-lbl">💰 Recaudado</div>
            <div class="kpi-val">$@Model.DineroTotalIngresado.ToString("N0")</div>
        </div>
        <div class="kpi">
            <div class="kpi-lbl">⚽ Deporte popular</div>
            <div class="kpi-val" style="font-size:1.05rem">@Model.DeporteMasPopular</div>
        </div>
    </div>

    <!-- Fila: pencas populares + tabla por sitio -->
    <div class="two-col">

        <div class="card">
            <div class="card-hdr">
                <div class="icon">🏅</div>
                <div>
                    <h5>Pencas más populares</h5>
                    <p>Por cantidad de sitios donde están activas</p>
                </div>
            </div>
            <div class="filters" id="filtrosPencas"></div>
            <div class="card-body">
                <div class="chart-wrap"><canvas id="chartPencas"></canvas></div>
            </div>
        </div>

        <div class="card">
            <div class="card-hdr">
                <div class="icon">🏢</div>
                <div>
                    <h5>Resumen por sitio</h5>
                    <p>Pencas, usuarios y recaudación</p>
                </div>
            </div>
            <div class="card-body" style="padding:0;">
                <table class="site-table">
                    <thead>
                        <tr>
                            <th>Sitio</th>
                            <th>Pencas</th>
                            <th>Jugadores</th>
                            <th>Recaudado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.EstadisticasPorSitio)
                        {
                            <tr>
                                <td><strong>@s.NombreSitio</strong></td>
                                <td>@s.CantidadPencas</td>
                                <td>@s.CantidadUsuarios.ToString("N0")</td>
                                <td>$@s.DineroRecaudado.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>

<!-- Gráfico: Recaudación Mensual -->
<div class="card">
    <div class="card-hdr">
        <div class="icon">💵</div>
        <div>
            <h5>Recaudación mensual</h5>
            <p>Ingresos por mes · filtrá por sitio y período</p>
        </div>
    </div>
    <div class="filters" style="flex-direction:column; gap:.75rem;">
        <div style="display:flex; gap:.4rem; flex-wrap:wrap;" id="filtrosRec"></div>
        <div style="display:flex; align-items:center; gap:.75rem; flex-wrap:wrap;">
            <div style="display:flex; align-items:center; gap:.4rem;">
                <label style="font-size:.75rem; font-weight:600; color:var(--brand);">Desde</label>
                <input type="month" id="recDesde" style="font-size:.78rem; padding:.2rem .5rem; border:1px solid var(--brand); border-radius:8px; color:var(--text-main); background:#fff; cursor:pointer;" />
            </div>
            <div style="display:flex; align-items:center; gap:.4rem;">
                <label style="font-size:.75rem; font-weight:600; color:var(--brand);">Hasta</label>
                <input type="month" id="recHasta" style="font-size:.78rem; padding:.2rem .5rem; border:1px solid var(--brand); border-radius:8px; color:var(--text-main); background:#fff; cursor:pointer;" />
            </div>
            <button class="fbtn" id="recLimpiar">Limpiar filtro</button>
        </div>
    </div>
    <div class="card-body">
        <div class="chart-wrap"><canvas id="chartRec"></canvas></div>
    </div>
</div>

    <!-- Gráfico: Evolución Usuarios -->
    <div class="card">
        <div class="card-hdr">
            <div class="icon">📈</div>
            <div>
                <h5>Evolución de usuarios</h5>
                <p>Registros por mes · filtrá por sitio</p>
            </div>
        </div>
        <div class="filters" id="filtrosUsr"></div>
        <div class="card-body">
            <div class="chart-wrap"><canvas id="chartUsr"></canvas></div>
        </div>
    </div>

</div>

<!-- Datos del servidor -->
<script>
    const datosRec = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.IngresosMensuales.Select(i => new {
            sitio = i.NombreSitio,
            anio  = i.Anio,
            mes   = i.Mes,
            monto = i.Monto
        })
    ));

    const datosUsr = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.EvolucionUsuarios.Select(u => new {
            sitio    = u.NombreSitio,
            anio     = u.Anio,
            mes      = u.Mes,
            cantidad = u.CantidadUsuarios
        })
    ));

    const datosPencas = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.PencasMasPopulares.Select(p => new {
            nombre     = p.NombrePenca,
            deporte    = p.Deporte,
            instancias = p.CantidadInstancias
        })
    ));
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
const MESES  = ["Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic"];
const PALETA = ["#e05c2a","#2ab5e0","#7c3aed","#0e9f6e","#d97706","#e02a6e","#1a56db","#b84318"];

function periodos(d) {
    const set = new Set(d.map(x => `${x.anio}-${String(x.mes).padStart(2,"0")}`));
    return [...set].sort().map(k => {
        const [a, m] = k.split("-");
        return { key: k, label: `${MESES[+m - 1]} ${a}` };
    });
}

function sitios(d) {
    return [...new Set(d.map(x => x.sitio))];
}

function buildDs(datos, ps, activo, campo) {
    const lista = activo === "Todos" ? sitios(datos) : [activo];
    return lista.map((s, i) => {
        const color = PALETA[i % PALETA.length];
        return {
            label: s,
            data: ps.map(p => {
                const [a, m] = p.key.split("-");
                const f = datos.find(d => d.sitio === s && d.anio === +a && d.mes === +m);
                return f ? f[campo] : 0;
            }),
            backgroundColor: color + "cc",
            borderColor: color,
            borderWidth: 1.5,
            borderRadius: 4,
        };
    });
}

function baseOpts(prefix) {
    return {
        responsive: true, maintainAspectRatio: false,
        plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: c => {
                const v = c.parsed.y;
                return prefix === "$"
                    ? ` ${c.dataset.label}: $${v.toLocaleString("es-UY", { minimumFractionDigits: 2 })}`
                    : ` ${c.dataset.label}: ${v} usuarios`;
            }}}
        },
        scales: {
            x: { grid: { display: false }, ticks: { color: "#6b7280", font: { size: 11 } } },
            y: { grid: { color: "#f3f4f6" }, ticks: { color: "#6b7280", font: { size: 11 },
                callback: v => prefix === "$" ? `$${v.toLocaleString("es-UY")}` : v
            }}
        }
    };
}

function makeFilters(containerId, datos, chart, campo) {
    const cont = document.getElementById(containerId);
    const ss = sitios(datos);
    const ps = periodos(datos);
    let activo = "Todos";
    ["Todos", ...ss].forEach(s => {
        const b = document.createElement("button");
        b.className = "fbtn" + (s === "Todos" ? " active" : "");
        b.textContent = s;
        b.onclick = () => {
            activo = s;
            cont.querySelectorAll(".fbtn").forEach(x => x.classList.remove("active"));
            b.classList.add("active");
            chart.data.datasets = buildDs(datos, ps, activo, campo);
            chart.update();
        };
        cont.appendChild(b);
    });
}

/* Recaudación */
(function () {
    let activoSitio = "Todos";
    let desdeKey = null;
    let hastaKey = null;

    function toKey(anio, mes) {
        return `${anio}-${String(mes).padStart(2, "0")}`;
    }

    function datosFiltrados() {
        return datosRec.filter(d => {
            const key = toKey(d.anio, d.mes);
            if (activoSitio !== "Todos" && d.sitio !== activoSitio) return false;
            if (desdeKey && key < desdeKey) return false;
            if (hastaKey && key > hastaKey) return false;
            return true;
        });
    }

    function periodosFiltrados() {
        return periodos(datosFiltrados());
    }

    function render() {
        const datos = datosFiltrados();
        const ps    = periodosFiltrados();
        const ss    = activoSitio === "Todos" ? sitios(datos) : [activoSitio];

        ch.data.labels   = ps.map(p => p.label);
        ch.data.datasets = buildDs(datos, ps, activoSitio, "monto");
        ch.update();
    }

    const ps = periodos(datosRec);
    const ch = new Chart(document.getElementById("chartRec"), {
        type: "bar",
        data: { labels: ps.map(p => p.label), datasets: buildDs(datosRec, ps, "Todos", "monto") },
        options: baseOpts("$")
    });

    /* Filtros por sitio */
    const cont = document.getElementById("filtrosRec");
    const ss   = sitios(datosRec);
    ["Todos", ...ss].forEach(s => {
        const b = document.createElement("button");
        b.className = "fbtn" + (s === "Todos" ? " active" : "");
        b.textContent = s;
        b.onclick = () => {
            activoSitio = s;
            cont.querySelectorAll(".fbtn").forEach(x => x.classList.remove("active"));
            b.classList.add("active");
            render();
        };
        cont.appendChild(b);
    });

    /* Filtros por fecha */
    document.getElementById("recDesde").addEventListener("change", e => {
        desdeKey = e.target.value || null;
        render();
    });
    document.getElementById("recHasta").addEventListener("change", e => {
        hastaKey = e.target.value || null;
        render();
    });
    document.getElementById("recLimpiar").addEventListener("click", () => {
        desdeKey = null;
        hastaKey = null;
        document.getElementById("recDesde").value = "";
        document.getElementById("recHasta").value = "";
        render();
    });
})();

/* Usuarios */
(function () {
    const ps = periodos(datosUsr);
    const ch = new Chart(document.getElementById("chartUsr"), {
        type: "bar",
        data: { labels: ps.map(p => p.label), datasets: buildDs(datosUsr, ps, "Todos", "cantidad") },
        options: baseOpts("")
    });
    makeFilters("filtrosUsr", datosUsr, ch, "cantidad");
})();

/* Pencas más populares */
(function () {
    const deportes = [...new Set(datosPencas.map(p => p.deporte))];
    let activo = "Todos";

    function renderChart() {
        const datos = (activo === "Todos" ? datosPencas : datosPencas.filter(p => p.deporte === activo))
            .slice().sort((a, b) => b.instancias - a.instancias);

        const labels = datos.map(p => p.nombre);
        const values = datos.map(p => p.instancias);
        const colors = labels.map((_, i) => PALETA[i % PALETA.length]);

        if (window._chartPencas) window._chartPencas.destroy();

        window._chartPencas = new Chart(document.getElementById("chartPencas"), {
            type: "bar",
            data: {
                labels,
                datasets: [{
                    label: "Instancias",
                    data: values,
                    backgroundColor: colors.map(c => c + "cc"),
                    borderColor: colors,
                    borderWidth: 1.5,
                    borderRadius: 4,
                }]
            },
            options: {
                indexAxis: "y",
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: c => ` ${c.parsed.x} instancias` } }
                },
                scales: {
                    x: {
                        grid: { color: "#f3f4f6" },
                        ticks: { color: "#6b7280", font: { size: 11 }, stepSize: 1 }
                    },
                    y: {
                        grid: { display: false },
                        ticks: { color: "#6b7280", font: { size: 11 } }
                    }
                }
            }
        });
    }

    const cont = document.getElementById("filtrosPencas");
    ["Todos", ...deportes].forEach(d => {
        const b = document.createElement("button");
        b.className = "fbtn" + (d === "Todos" ? " active" : "");
        b.textContent = d;
        b.onclick = () => {
            activo = d;
            cont.querySelectorAll(".fbtn").forEach(x => x.classList.remove("active"));
            b.classList.add("active");
            renderChart();
        };
        cont.appendChild(b);
    });

    renderChart();
})();
</script>