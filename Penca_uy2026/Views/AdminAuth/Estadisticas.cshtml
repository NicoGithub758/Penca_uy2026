@model Penca_uy2026.Models.ViewModels.EstadisticasViewModel

@{
    ViewData["Title"] = "Estadísticas Globales";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-speedometer2"></i> Panel de Control Global</h2>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card p-3 shadow-sm border-0 text-center h-100">
                <h6 class="text-muted text-uppercase small">Total Pencas</h6>
                <h3 class="fw-bold text-primary">@Model.TotalPencas</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 shadow-sm border-0 text-center h-100">
                <h6 class="text-muted text-uppercase small">Dinero Recaudado</h6>
                <h3 class="fw-bold text-success">$@Model.DineroTotalIngresado.ToString("N2")</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 shadow-sm border-0 text-center h-100">
                <h6 class="text-muted text-uppercase small">Usuarios Totales</h6>
                <h3 class="fw-bold text-dark">@Model.TotalUsuarios</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 shadow-sm border-0 text-center h-100">
                <h6 class="text-muted text-uppercase small">Deporte Favorito</h6>
                <h3 class="fw-bold text-info">@Model.DeporteMasPopular</h3>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">Rendimiento por Sitio</h5>
            <span class="badge bg-light text-dark">Datos en tiempo real</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Sitio</th>
                        <th>Pencas</th>
                        <th>Recaudación</th>
                        <th>Admins</th>
                        <th>Usuarios</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.EstadisticasPorSitio)
                    {
                        <tr>
                            <td class="ps-4"><strong>@s.NombreSitio</strong></td>
                            <td><span class="text-primary fw-bold">@s.CantidadPencas</span></td>
                            <td>$@s.DineroRecaudado.ToString("N2")</td>
                            <td><span class="badge bg-dark rounded-pill">@s.CantidadAdmins</span></td>
                            <td><span class="badge bg-secondary rounded-pill">@s.CantidadUsuarios</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>