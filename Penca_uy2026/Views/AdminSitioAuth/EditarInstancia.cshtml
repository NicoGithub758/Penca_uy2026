@model Penca_uy2026.Models.PencaInstancia

@{
    ViewData["Title"] = "Editar Comisión";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0 text-primary">
                        <i class="bi bi-pencil-square"></i> Editar Comisión
                    </h4>
                </div>
                <div class="card-body p-4">
                    <h5 class="card-title mb-4">@Model.Penca.Nombre</h5>
                    
                    <form asp-action="EditarInstancia" method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-4">
                            <label asp-for="PorcentajeComision" class="form-label fw-bold">Porcentaje de Comisión (%)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-percent"></i></span>
                                <input asp-for="PorcentajeComision" type="number" step="0.1" class="form-control form-control-lg" placeholder="Ej: 10.5" />
                            </div>
                            <div class="form-text">Define el porcentaje que se quedará el sitio por esta penca.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Costo" class="form-label fw-bold">Costo de Entrada</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-currency-dollar"></i></span>
                                <input asp-for="Costo" type="number" step="0.01" class="form-control form-control-lg" placeholder="Ej: 500" />
                            </div>
                            <div class="form-text">Define el costo para participar en esta penca.</div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check2-circle"></i> Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>