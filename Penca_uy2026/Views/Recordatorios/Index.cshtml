@using Penca_uy2026.Models.ViewModels
@{
    ViewData["Title"] = "Gestión de Recordatorios";
    var configuracion = ViewBag.Configuracion as ConfiguracionSitioViewModel ?? new ConfiguracionSitioViewModel();
    var anuncio = ViewBag.Anuncio as EnviarAnuncioViewModel ?? new EnviarAnuncioViewModel();
}

<div class="container my-4">

    <h2 class="mb-4">🔔 Gestión de Recordatorios</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">

        <!-- ============================================================ -->
        <!-- CONFIGURACION DE RECORDATORIOS AUTOMATICOS                   -->
        <!-- ============================================================ -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <strong>⚙️ Recordatorios Automáticos</strong>
                </div>
                <div class="card-body">
                    <p class="text-muted small">
                        El sistema envía recordatorios push automáticos antes de cada partido
                        a los participantes que aún no hicieron su predicción.
                    </p>

                    <form asp-action="GuardarConfiguracion" method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox"
                                   id="RecordatoriosAutomaticosActivos"
                                   name="RecordatoriosAutomaticosActivos"
                                   value="true"
                                   @(configuracion.RecordatoriosAutomaticosActivos ? "checked" : "") />
                            <label class="form-check-label" for="RecordatoriosAutomaticosActivos">
                                Activar recordatorios automáticos
                            </label>
                        </div>

                        <div class="mb-3">
                            <label for="HorasAntes" class="form-label">¿Cuántas horas antes del partido?</label>
                            <select class="form-select" id="HorasAntes" name="HorasAntes">
                                <option value="1" selected="@(configuracion.HorasAntes == 1)">1 hora antes</option>
                                <option value="3" selected="@(configuracion.HorasAntes == 3)">3 horas antes</option>
                                <option value="6" selected="@(configuracion.HorasAntes == 6)">6 horas antes</option>
                                <option value="12" selected="@(configuracion.HorasAntes == 12)">12 horas antes</option>
                                <option value="24" selected="@(configuracion.HorasAntes == 24)">24 horas antes</option>
                                <option value="48" selected="@(configuracion.HorasAntes == 48)">48 horas antes</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary">Guardar configuración</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- ============================================================ -->
        <!-- ENVIAR ANUNCIO INMEDIATO                                     -->
        <!-- ============================================================ -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-info text-white">
                    <strong>📣 Enviar anuncio a una penca</strong>
                </div>
                <div class="card-body">
                    <p class="text-muted small">
                        Enviá una notificación push inmediata a todos los participantes
                        de una penca específica.
                    </p>

                    @if (!anuncio.PencasDisponibles.Any())
                    {
                        <div class="alert alert-warning small">
                            No hay pencas creadas en este sitio para enviar anuncios.
                        </div>
                    }
                    else
                    {
                        <form asp-action="EnviarAnuncio" method="post">
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label for="PencaInstanciaId" class="form-label">Penca destino</label>
                                <select class="form-select" id="PencaInstanciaId" name="PencaInstanciaId" required>
                                    <option value="">-- Elegí una penca --</option>
                                    @foreach (var p in anuncio.PencasDisponibles)
                                    {
                                        <option value="@p.Id">@p.Nombre</option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="Titulo" class="form-label">Título</label>
                                <input type="text" class="form-control" id="Titulo" name="Titulo"
                                       maxlength="100" required
                                       placeholder="Ej: ¡Recordá predecir!" />
                                <small class="form-text text-muted">Máx. 100 caracteres.</small>
                            </div>

                            <div class="mb-3">
                                <label for="Mensaje" class="form-label">Mensaje</label>
                                <textarea class="form-control" id="Mensaje" name="Mensaje"
                                          rows="3" maxlength="500" required
                                          placeholder="Ej: La penca cierra mañana, no te olvides."></textarea>
                                <small class="form-text text-muted">Máx. 500 caracteres.</small>
                            </div>

                            <button type="submit" class="btn btn-info text-white"
                                    onclick="return confirm('¿Enviar esta notificación push ahora?');">
                                📤 Enviar ahora
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>

    </div>

    <div class="mt-3">
        <a asp-controller="AdminSitioAuth" asp-action="Index" class="btn btn-secondary btn-sm">← Volver al panel</a>
    </div>

</div>
