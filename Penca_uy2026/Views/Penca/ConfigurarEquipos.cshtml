@model int

@{
    ViewData["Title"] = "Configurar Equipos";
}

<div class="container mt-5">
    <div class="card shadow-sm mx-auto" style="max-width: 700px; border-radius: 15px;">
        <div class="card-header bg-dark text-white text-center py-3" style="border-radius: 15px 15px 0 0;">
            <h3 class="mb-0">Configuración de Participantes</h3>
            <small class="text-light">Penca: @ViewBag.PencaNombre</small>
        </div>
        <div class="card-body p-4">
            <p class="text-muted text-center mb-4">
                Ingresa los nombres de los <strong>@Model</strong> equipos que participarán en esta competición.
            </p>

            <form asp-action="GuardarEquipos" method="post">
                <input type="hidden" name="pencaId" value="@ViewBag.PencaId" />
                
                <div class="row">
                    @for (int i = 0; i < Model; i++)
                    {
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-primary">Equipo @(i + 1)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-shield"></i></span>
                                <input type="text" name="nombresEquipos" class="form-control" placeholder="Nombre del equipo..." required />
                            </div>
                        </div>
                    }
                </div>

                <hr class="my-4">

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-success btn-lg w-100">
                        <i class="bi bi-check-circle"></i> Guardar Participantes
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>