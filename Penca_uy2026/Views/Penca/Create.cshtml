@model List<Penca_uy2026.DTOs.ApiFootballLigaDto>
<div class="container mt-5">
    <h2 class="mb-4">Crear penca desde competición</h2>

    <div class="row">
        @foreach (var liga in Model)
        {
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <img src="@liga.LogoUrl"
                             alt="@liga.Nombre"
                             style="height: 70px; object-fit: contain;"
                             class="mb-3" />

                        <h5 class="card-title">@liga.Nombre</h5>

                        <p class="text-muted mb-1">@liga.Pais</p>
                        <small class="text-muted">Temporada @liga.Temporada</small>
                    </div>

                    <div class="card-footer bg-white border-0">
                        <form asp-action="CrearDesdeCompeticion" method="post">
                            <input type="hidden" name="leagueId" value="@liga.LeagueId" />
                            <input type="hidden" name="season" value="@liga.Temporada" />
                            <input type="hidden" name="nombreLiga" value="@liga.Nombre" />
                            <input type="hidden" name="pais" value="@liga.Pais" />
                            <input type="hidden" name="logoUrl" value="@liga.LogoUrl" />

                            <button type="submit" class="btn btn-primary w-100">
                                Agregar
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>